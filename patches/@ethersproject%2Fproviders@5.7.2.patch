+async function resolveNameImpl(provider, Resolver, resolveNameOrig, name, coinType) {
+  if (coinType === 'old') {
+    return resolveNameOrig.call(provider, name)
+  }
+  if (coinType === undefined || coinType === null) {
+    coinType = COIN_TYPE_ETH
+  }
+  const awaitedName = await name
+  const coinTypeBn = BigNumber.from(coinType).toBigInt()
+  if (isHexString(awaitedName) && awaitedName.length === 42) {
