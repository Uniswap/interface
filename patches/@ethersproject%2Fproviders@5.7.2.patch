+}
+
+function getReverseName(lowerAddress, coinType) {
+  return `${lowerAddress.slice(2)}.${
+    coinType === COIN_TYPE_ETH
+      ? 'addr'
+      : coinType === COIN_TYPE_DEFAULT
+        ? 'default'
+        : coinType.toString(16)
+  }.reverse`
+}
+
+function namesplit(name) {
+  return name ? name.split('.') : []
+}
+
