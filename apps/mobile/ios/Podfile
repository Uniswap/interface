# should be removed after migrating to react-native new architecture
ENV['RCT_NEW_ARCH_ENABLED'] = '0'
# changes from here: https://docs.expo.dev/bare/installing-expo-modules/
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")

# Helper function to read Podfile.properties (Expo 54+)
def read_podfile_properties
  properties = {}
  podfile_dir = File.dirname(__FILE__)
  # Try JSON format first (expo-build-properties), then fall back to key=value format
  podfile_properties_json_path = File.join(podfile_dir, 'Podfile.properties.json')
  podfile_properties_path = File.join(podfile_dir, 'Podfile.properties')
  
  if File.exist?(podfile_properties_json_path)
    require 'json'
    properties = JSON.parse(File.read(podfile_properties_json_path)) rescue {}
  elsif File.exist?(podfile_properties_path)
    File.readlines(podfile_properties_path).each do |line|
      line = line.strip
      next if line.empty? || line.start_with?('#')
      key, value = line.split('=', 2)
      properties[key.strip] = value&.strip if key
    end
  end
  properties
end

podfile_properties = read_podfile_properties
ENV['RCT_USE_RN_DEP'] = '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] = '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
require_relative '../../../node_modules/react-native/scripts/react_native_pods'
require_relative '../../../node_modules/react-native-permissions/scripts/setup'

platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'
prepare_react_native_project!

setup_permissions([
  'FaceID',
  'Notifications',
])

$RNFirebaseAsStaticFramework = true
$RNFirebaseAnalyticsWithoutAdIdSupport=true

project 'Uniswap',
  'Debug' => :debug,
  'DebugOptimized' => :debug,
  'Release' => :release,
  'Dev' => :release,
  'Beta' => :release

target 'Uniswap' do
  use_frameworks! :linkage => :static
  use_expo_modules!
  post_integrate do |installer|
    begin
      expo_patch_react_imports!(installer)
    rescue => e
      Pod::UI.warn e
    end
  end

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_react_native!(
    :path => config[:reactNativePath],
    :fabric_enabled => false,
    # to enable hermes on iOS, change `false` to `true` and then install pods
    :hermes_enabled => true
  )

  target 'UniswapTests' do
    inherit! :complete
    # Pods for testing
  end

  pod 'EthersRS', :path =>  '../../../node_modules/@uniswap/ethers-rs-mobile'
  pod 'Argon2Swift', '1.0.3'

  post_install do |installer|
    react_native_post_install(installer, "../../../node_modules/react-native")

    # fmt 11.0.2 (shipped with RN 0.81) hits a consteval miscompilation under
    # Xcode 26's Apple clang: FMT_STRING expands to a struct returned from a
    # constexpr lambda whose value is then passed to a consteval ctor, which
    # the new compiler refuses to fold. fmt 11.1+ fixes this, but RN pins
    # 11.0.2 and base.h's FMT_USE_CONSTEVAL macro chain isn't `#ifndef`-guarded
    # so a -D override is clobbered by the headers. Patch base.h in place to
    # force-disable consteval; the patch re-applies on every `pod install`.
    fmt_base_h = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_h)
      content = File.read(fmt_base_h)
      sentinel = '// rn-upgrade FMT_USE_CONSTEVAL force-disabled for Xcode 26'
      unless content.include?(sentinel)
        # Replace the entire FMT_USE_CONSTEVAL detection block (which spans
        # multiple `#elif` branches and re-enables consteval on Apple clang
        # >= 14000029) with an unconditional `#define FMT_USE_CONSTEVAL 0`.
        block_start = "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#if !defined(__cpp_lib_is_constant_evaluated)"
        idx = content.index(block_start)
        if idx
          # Find the matching #endif after the block (the one before "#if FMT_USE_CONSTEVAL")
          tail_anchor = "#endif\n#if FMT_USE_CONSTEVAL"
          end_idx = content.index(tail_anchor, idx)
          if end_idx
            new_block = "// Detect consteval, C++20 constexpr extensions and std::is_constant_evaluated.\n#define FMT_USE_CONSTEVAL 0  #{sentinel}\n"
            new_content = content[0...idx] + new_block + content[(end_idx + "#endif\n".length)..-1]
            File.chmod(0644, fmt_base_h)
            File.write(fmt_base_h, new_content)
          else
            Pod::UI.warn "fmt FMT_USE_CONSTEVAL patch: tail anchor not found"
          end
        else
          Pod::UI.warn "fmt FMT_USE_CONSTEVAL patch: block start not found"
        end
      end
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['APPLICATION_EXTENSION_API_ONLY'] = 'No'

        # Optimize native code in DebugOptimized for faster Simulator runtime.
        # Hermes ships pre-compiled and is unaffected. Source-compiled pods
        # (Yoga, React-Core, RNScreens, RNReanimated, RNGestureHandler, etc.)
        # run dramatically faster with optimization enabled.
        # RN dev tools (Metro, React DevTools) work over the network and are unaffected.
        if config.name == 'DebugOptimized'
          config.build_settings['GCC_OPTIMIZATION_LEVEL'] = 's'
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-O'
          config.build_settings['MTL_ENABLE_DEBUG_INFO'] = 'NO'
        end
      end
    end

    # Xcode 26+ has a stricter module verifier that requires the consuming target
    # to resolve transitive C module dependencies. Argon2Swift depends on an internal
    # 'argon2' C module — add its modulemap path to every target that imports
    # Argon2Swift (the main Uniswap aggregate + any pod target like RNArgon2 that
    # pulls it in as a Swift dep).
    argon2_srcroot = installer.sandbox.pod_dir('Argon2Swift')
    argon2_module_paths = [
      "#{argon2_srcroot}/Sources/Modules",
      "#{argon2_srcroot}/Sources/Argon2",
      "#{argon2_srcroot}/Sources/Argon2/include",
    ]
    argon2_swift_include_flag = argon2_module_paths.map { |p| "\"#{p}\"" }.join(' ')

    uniswap_aggregate = installer.aggregate_targets.find { |t| t.label == 'Pods-Uniswap' }
    if uniswap_aggregate
      uniswap_aggregate.xcconfigs.each do |config_name, xcconfig|
        existing = xcconfig.attributes['SWIFT_INCLUDE_PATHS'] || ''
        xcconfig.attributes['SWIFT_INCLUDE_PATHS'] = "$(inherited) #{argon2_swift_include_flag} #{existing}".strip
        xcconfig_path = uniswap_aggregate.xcconfig_path(config_name)
        xcconfig.save_as(xcconfig_path)
      end
    end

    # Propagate SWIFT_INCLUDE_PATHS to pod targets that link Argon2Swift (notably
    # RNArgon2, whose Swift source does `import Argon2Swift`). Without this, Xcode's
    # module verifier fails with "Unable to resolve module dependency: 'argon2'".
    installer.pods_project.targets.each do |target|
      next unless target.respond_to?(:name)
      next unless target.name == 'RNArgon2'
      target.build_configurations.each do |config|
        existing = config.build_settings['SWIFT_INCLUDE_PATHS'] || '$(inherited)'
        unless existing.include?(argon2_module_paths.first)
          config.build_settings['SWIFT_INCLUDE_PATHS'] = "#{existing} #{argon2_swift_include_flag}"
        end
      end
    end
  end
end

