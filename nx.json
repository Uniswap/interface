{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "defaultBase": "main",
  "tui": {
    "enabled": false
  },
  "s3": {
    "region": "us-east-2",
    "bucket": "uniswap-nx-remote-cache-prod",
    "cacheKeyPrefix": "nx-cache/universe/",
    "localMode": "no-cache",
    "ciMode": "no-cache"
  },
  "targetDefaults": {
    "prepare": {
      "cache": true
    },
    "config:pull": {
      "dependsOn": ["^prepare"],
      "cache": true,
      "inputs": [
        { "env": "USE_NEW_CONFIGS" },
        { "env": "CONFIG_ENV" },
        { "env": "SKIP_CONFIG_PULL" },
        { "runtime": "date -u +%Y-%m-%dT%H" },
        "ciCacheBust"
      ],
      "outputs": ["{projectRoot}/.env.new"]
    },
    "build:production": {
      "dependsOn": ["^prepare", "prepare"],
      "inputs": ["dependencies", "production"],
      "outputs": ["{projectRoot}/build"],
      "cache": true
    },
    "typecheck": {
      "command": "if test \"$DISABLE_TSGO\" = \"true\"; then bun run nx typecheck:tsc; else bun run nx typecheck:tsgo; fi",
      "options": {
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["^prepare", "prepare"],
      "cache": false
    },
    "typecheck:tsc": {
      "command": "NODE_OPTIONS=--max_old_space_size=16384 tsc -b",
      "options": {
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/config/tsconfig/*",
        "{workspaceRoot}/tsconfig.base.json",
        "{projectRoot}/package.json",
        "{projectRoot}/tsconfig.*.json",
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/**/*.json",
        {
          "dependentTasksOutputFiles": "**/*.d.ts"
        }
      ],
      "outputs": ["{workspaceRoot}/dist/out-tsc/{projectRoot}"],
      "cache": true
    },
    "typecheck:tsgo": {
      "command": "tsgo -b",
      "options": {
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/config/tsconfig/*",
        "{workspaceRoot}/tsconfig.base.json",
        "{projectRoot}/package.json",
        "{projectRoot}/tsconfig.*.json",
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/**/*.json",
        {
          "dependentTasksOutputFiles": "**/*.d.ts"
        }
      ],
      "outputs": ["{workspaceRoot}/dist/out-tsc/{projectRoot}"],
      "cache": true
    },
    "format:check": {
      "command": "oxfmt --check --threads=2 -c $NX_WORKSPACE_ROOT/.oxfmtrc.json .",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["formattableFiles", "lintConfig"]
    },
    "format": {
      "command": "oxfmt --threads=2 -c $NX_WORKSPACE_ROOT/.oxfmtrc.json .",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": ["formattableFiles", "lintConfig"]
    },
    "lint:oxlint": {
      "command": "oxlint --threads=2 -c oxlint.config.ts {projectRoot}",
      "dependsOn": ["prepare"],
      "cache": true,
      "inputs": ["sourceFiles", "lintConfig"]
    },
    "lint:oxlint:fix": {
      "command": "oxlint --fix --threads=2 -c oxlint.config.ts {projectRoot}",
      "dependsOn": ["prepare"],
      "cache": false
    },
    "lint:oxlint:fast": {
      "command": "ENABLE_FAST_LINT=true oxlint --threads=2 -c oxlint.config.ts {projectRoot}",
      "dependsOn": ["prepare"],
      "cache": true,
      "inputs": ["sourceFiles", "lintConfig"]
    },
    "lint:typeaware-custom": {
      "dependsOn": ["prepare"],
      "cache": true,
      "inputs": ["sourceFiles", "lintConfig", "{workspaceRoot}/config/oxlint-plugins/typeaware-custom.ts"]
    },
    "lint": {
      "executor": "nx:noop",
      "dependsOn": ["prepare", "lint:oxlint", "lint:typeaware-custom"]
    },
    "lint:fix": {
      "executor": "nx:noop",
      "dependsOn": ["prepare", "lint:oxlint:fix"],
      "cache": false
    },
    "check": {
      "executor": "nx:noop",
      "dependsOn": ["prepare", "format", "typecheck", "lint", "check:circular", "check:deps:usage"]
    },
    "check:fast": {
      "executor": "nx:noop",
      "dependsOn": ["prepare", "format", "typecheck", "lint:oxlint:fast"]
    },
    "check:circular": {
      "inputs": ["sourceFiles"],
      "cache": true
    },
    "check:deps:usage": {
      "command": "bun --preload ./scripts/silence-deprecation-warnings.js ./node_modules/.bin/knip-bun --include dependencies,devDependencies --no-progress --no-config-hints --workspace {projectRoot}",
      "options": {
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["sourceFiles", "{workspaceRoot}/knip.json", "{workspaceRoot}/bun.lock"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^prepare", "prepare"],
      "inputs": ["sourceFiles", "^production", "{projectRoot}/**/*.test.*", "{projectRoot}/**/*.spec.*"],
      "cache": true
    },
    "start": {
      "dependsOn": ["^prepare", "prepare"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^prepare", "prepare"],
      "cache": false
    },
    "snapshots": {
      "dependsOn": ["^prepare", "prepare"],
      "cache": true
    },
    "graphql:schema": {
      "inputs": ["{workspaceRoot}/.env.production", "{projectRoot}/graphql.*.ts"],
      "outputs": ["{projectRoot}/schema.graphql"],
      "cache": true
    },
    "graphql:generate": {
      "inputs": [
        "{projectRoot}/codegen.ts",
        "{projectRoot}/src/**/schema.graphql",
        "{projectRoot}/src/**/queries.graphql",
        "{projectRoot}/src/**/fragments.ts",
        "{projectRoot}/src/**/queries.ts",
        "{projectRoot}/src/graphql/**",
        "{projectRoot}/src/data/**/*.graphql"
      ],
      "outputs": [
        "{projectRoot}/src/data/graphql/**/__generated__/**",
        "{projectRoot}/data/__generated__/**",
        "{projectRoot}/graphql/__generated__/**"
      ],
      "cache": true
    }
  },
  "namedInputs": {
    "production": [
      "dependencies",
      "tsConfig",
      "{projectRoot}/**/*",
      "!{projectRoot}/**/*.spec.tsx",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.tsx",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/**/*.stories.tsx",
      "!{projectRoot}/**/*.stories.ts"
    ],
    "lintConfig": ["{workspaceRoot}/.oxfmtrc.json", "{workspaceRoot}/oxlint.config.ts"],
    "mobileGlobals": ["{workspaceRoot}/metro.config.*", "{workspaceRoot}/Gemfile*"],
    "sourceFiles": [
      "dependencies",
      "tsConfig",
      "{projectRoot}/**/*.ts",
      "{projectRoot}/**/*.tsx",
      "{projectRoot}/**/*.cts",
      "{projectRoot}/**/*.mts",
      "{projectRoot}/**/*.js",
      "{projectRoot}/**/*.jsx",
      "{projectRoot}/**/*.cjs",
      "{projectRoot}/**/*.mjs"
    ],
    "formattableFiles": [
      "sourceFiles",
      "{projectRoot}/**/*.json",
      "{projectRoot}/**/*.jsonc",
      "{projectRoot}/**/*.json5"
    ],
    "dependencies": ["{workspaceRoot}/package.json", "{projectRoot}/package.json"],
    "tsConfig": ["{workspaceRoot}/tsconfig.base.json", "{workspaceRoot}/tsconfig.json", "{projectRoot}/tsconfig*.json"],
    "ciCacheBust": [{ "env": "GITHUB_RUN_ID" }, { "env": "GITHUB_RUN_ATTEMPT" }]
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "sync": {
    "applyChanges": true,
    "globalGenerators": ["@nx/js:typescript-sync"]
  },
  "parallel": 6,
  "defaultProject": "@universe/web",
  "generators": {
    "@nx/js:library": {
      "buildable": false
    }
  },
  "cacheDirectory": ".nx/cache",
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": false,
        "build": false
      }
    }
  ],
  "pluginsConfig": {
    "@nx/js": {
      "analyzeSourceFiles": true
    }
  }
}
