{
  "extends": "../../config/tsconfig/app.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.json"
  ],
  "references": [
    {
      "path": "../ui"
    },
    {
      "path": "../uniswap"
    },
    {
      "path": "../utilities"
    }
  ],
  "compilerOptions": {
    "paths": {
      "ui/src/*": ["../../dist/out-tsc/packages/ui/src/*"],
      "utilities/src/*": ["../../dist/out-tsc/packages/utilities/src/*"],
      "uniswap/src/*": ["../../dist/out-tsc/packages/uniswap/src/*"]
    },
    "types": [
      "chrome",
      "jest"
    ]
  }
}
