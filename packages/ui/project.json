{
  "tags": ["scope:ui", "type:lib"],
  "targets": {
    "prepare": {
      "dependsOn": ["build:icons"]
    },
    "build:icons": {
      "command": "bun run ./src/scripts/componentize-icons.ts --silent && oxfmt --threads=2 -c $NX_WORKSPACE_ROOT/.oxfmtrc.json src/components/icons src/components/logos",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "lintConfig",
        "{projectRoot}/src/scripts/componentize-icons.ts",
        "{projectRoot}/src/assets/icons/**",
        "{projectRoot}/src/assets/logos/**",
        "ciCacheBust"
      ],
      "outputs": ["{projectRoot}/src/components/icons/**", "{projectRoot}/src/components/logos/**"]
    },
    "build:icons:missing": {
      "command": "bun run ./src/scripts/componentize-icons.ts --skip-existing --silent && oxfmt --threads=4 -c $NX_WORKSPACE_ROOT/.oxfmtrc.json src/components/icons src/components/logos",
      "options": {
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/scripts/componentize-icons.ts",
        "{projectRoot}/src/assets/icons/**",
        "{projectRoot}/src/assets/logos/**",
        "ciCacheBust"
      ],
      "outputs": ["{projectRoot}/src/components/icons/**", "{projectRoot}/src/components/logos/**"]
    },
    "typecheck": {},
    "typecheck:tsc": {},
    "typecheck:tsgo": {},
    "format": {
      "command": "oxfmt --threads=4 -c $NX_WORKSPACE_ROOT/.oxfmtrc.json . '!src/components/icons' '!src/components/logos'"
    },
    "format:check": {},
    "lint:oxlint": {},
    "lint:oxlint:fix": {},
    "lint:oxlint:fast": {},
    "lint": {},
    "lint:fix": {},
    "check": {},
    "check:fast": {},
    "check:deps:usage": {},
    "test": {
      "command": "vitest run",
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
