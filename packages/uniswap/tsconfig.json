{
  "extends": "../../config/tsconfig/app.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "src/**/*.mts"
  ],
  "references": [
    {
      "path": "../ui"
    },
    {
      "path": "../utilities"
    },
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ring-protocol/v2-sdk": ["../../node_modules/@ring-protocol/v2-sdk"],
      "@ring-protocol/v3-sdk": ["../../node_modules/@ring-protocol/v3-sdk"],
      "@ring-protocol/v4-sdk": ["../../node_modules/@ring-protocol/v4-sdk"],
      "@ring-protocol/sdk-core": ["../../node_modules/@ring-protocol/sdk-core"],
      "@ring-protocol/universal-router-sdk": ["../../node_modules/@ring-protocol/universal-router-sdk"],
      "@ring-protocol/router-sdk": ["../../node_modules/@ring-protocol/router-sdk"],
      "@uniswap/*": ["../../node_modules/@uniswap/*"]
    },
    "types": [
      "chrome",
      "jest"
    ]
  }
}
