.env.new
.env.new.override

# turbo
.turbo

# nx
# `.nx/*` (not `.nx/`) so the activation key in .nx/key/ can be re-included
# — git cannot un-exclude a path under a directory-excluded parent.
.nx/*
!.nx/key/
graph.json

# .yarn files
.yarn/cache
.yarn/versions
.yarn/install-state.gz

# typescript
dist/out-tsc/*
tsconfig.tsbuildinfo

# Locale backup/generated files
packages/uniswap/src/i18n/locales/source/*_old.json

# ci
.ci-cache/

# cli gh analysis artifacts
.analysis/

# JetBrains
.idea/

# Vercel
.vercel

# CodeTours Extension
.tours/*

# Expo
.expo/

# Watchman
.watchman-cookie-*

# auto-generated test ids
apps/mobile/.maestro/scripts/testIds.js

# claude
claude.local.md
CLAUDE.local.md
.claude/settings.local.json
.claude/local/
.claude/worktrees/
.claude/skills/*-workspace/
**/*/.claude/user/*
**/*/.claude/local/

# cursor
.cursor/mcp.json
.cursor/rules/local-workflow.mdc
.cursor/*.log

# argent — skills-lock.json carries per-user absolute paths; the .agents/skills/ tree itself is committed (editor-side .claude/skills/argent-* are symlinks into it)
skills-lock.json
# Literal "~" dir created when a tool fails to expand $HOME (e.g. argent mcp-calls.log)
/~/

# lefthook
.lefthook/

