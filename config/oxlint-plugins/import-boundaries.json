{
  "boundaries": [
    {
      "id": "toucan-feature",
      "mode": "importerAllowlist",
      "importerInternalPathMarkers": ["/features/Toucan/"],
      "allowedImporterPathMarkers": ["/pages/Explore/", "/features/Explore/state"],
      "importPrefixes": ["~/features/Toucan/", "features/Toucan/"],
      "bareModuleSources": ["~/features/Toucan", "features/Toucan"],
      "message": "Toucan feature code may only be imported from pages/Explore/, features/explore/state, or from within features/Toucan/."
    },
    {
      "id": "liquidity-feature",
      "mode": "importerAllowlist",
      "importerInternalPathMarkers": ["/features/Liquidity/"],
      "allowedImporterPathMarkers": [
        "/pages/AddLiquidity/",
        "/pages/CreatePosition/",
        "/pages/Explore/",
        "/pages/IncreaseLiquidity/",
        "/pages/LegacyPool/",
        "/pages/Liquidity/",
        "/pages/Migrate/",
        "/pages/PoolDetails/",
        "/pages/PoolFinder/",
        "/pages/Portfolio/",
        "/pages/Positions/",
        "/pages/RemoveLiquidity/",
        "/app/layout/TopLevelModals/"
      ],
      "importPrefixes": ["~/features/Liquidity/", "features/Liquidity/"],
      "bareModuleSources": ["~/features/Liquidity", "features/Liquidity"],
      "message": "Liquidity feature code may only be imported from the allowlisted page routes, D3LiquidityChartShared, TopLevelModals, or from within features/Liquidity/"
    },
    {
      "id": "swap-feature",
      "mode": "importerAllowlist",
      "importerInternalPathMarkers": ["/features/Swap/"],
      "allowedImporterPathMarkers": [
        "/pages/Swap/",
        "/pages/TokenDetails/",
        "/pages/Landing/",
        "/app/WebUniswapContext",
        "/features/Liquidity/Create/"
      ],
      "importPrefixes": ["~/features/Swap/", "features/Swap/"],
      "bareModuleSources": ["~/features/Swap", "features/Swap"],
      "message": "The Swap feature may only be imported from pages/Swap/, pages/TokenDetails/, pages/Landing/, app/WebUniswapContext, features/Liquidity/Create/, or from within features/Swap/."
    },
    {
      "id": "explore-feature",
      "mode": "importerAllowlist",
      "importerInternalPathMarkers": ["/features/Explore/"],
      "allowedImporterPathMarkers": [
        "/pages/AddLiquidity/",
        "/pages/Explore/",
        "/pages/Landing/",
        "/pages/PoolDetails/",
        "/pages/Positions/",
        "/pages/TokenDetails/",
        "/features/Toucan/"
      ],
      "importPrefixes": ["~/features/Explore/", "features/Explore/"],
      "bareModuleSources": ["~/features/Explore", "features/Explore"],
      "message": "The Explore feature may only be imported from pages/AddLiquidity/, pages/Explore/, pages/Landing/, pages/PoolDetails/, pages/Positions/, pages/TokenDetails/, features/Toucan/ or from within features/Explore/."
    },
    {
      "id": "web-state-import-denylist",
      "mode": "importerDenylist",
      "deniedImporterPathMarkers": ["/apps/web/src/state/"],
      "importPrefixes": ["~/features/", "features/", "~/components/", "components/"],
      "bareModuleSources": ["~/features", "features", "~/components", "components"],
      "message": "apps/web `src/state` must not import from `~/features/` or `~/components/`"
    }
  ]
}
